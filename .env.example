# Apple Silicon macOS container-lab settings
#
# Ubuntu Server uses native GitLab CE and Runner packages. It does not use this
# file; follow README_ubuntu.md instead.
#
# Community server image and matched runner for arm64:
# GITLAB_IMAGE=docker.io/yrzr/gitlab-ce-arm64v8:18.9.0-ce.0
# GITLAB_RUNNER_IMAGE=docker.io/gitlab/gitlab-runner:v18.9.0
# These match the pinned Compose defaults. Uncomment them only to make the
# selected versions explicit in a local `.env` file.
# GITLAB_EXTERNAL_URL=http://localhost:8088
# GITLAB_REGISTRY_URL=http://localhost:5005
# PODMAN_SOCKET=/run/podman/podman.sock
