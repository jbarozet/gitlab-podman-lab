# Podman GitLab lab settings

#--- [ Ubuntu Server ] ---
#
# For a fresh amd64 installation, uncomment the matched image pair and the
# three common settings. Replace the host with the server's LAN IP or DNS name.
# Keep this lab off untrusted networks.
#
# Official images for a fresh amd64 installation:
# Keep the docker.io prefix. Podman installations without an unqualified-search
# registry reject short names such as gitlab/gitlab-ce.
# GITLAB_IMAGE=docker.io/gitlab/gitlab-ce:19.1.2-ce.0
# GITLAB_RUNNER_IMAGE=docker.io/gitlab/gitlab-runner:v19.1.1
#
# Replace with the server's LAN IP address or resolvable DNS name
# GITLAB_EXTERNAL_URL=http://gitlab.example.test:8088
# GITLAB_REGISTRY_URL=http://gitlab.example.test:5005
#
# Replace 1000 if `id -u` prints a different value
# PODMAN_SOCKET=/run/user/1000/podman/podman.sock

#--- [ Apple Silicon macOS ] ---
#
# Community server image and matched runner for arm64:
# GITLAB_IMAGE=docker.io/yrzr/gitlab-ce-arm64v8:18.9.0-ce.0
# GITLAB_RUNNER_IMAGE=docker.io/gitlab/gitlab-runner:v18.9.0
# These match the pinned Compose defaults. Uncomment them only to make the
# selected versions explicit in a local `.env` file.
