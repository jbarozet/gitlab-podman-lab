# python:3.12-slim is Debian-based (glibc) and avoids musl/Alpine
# compatibility issues with Python packages that have C extensions.
# build.sh selects linux/arm64 or linux/amd64 from the host architecture.
#
FROM python:3.12-slim

# 1. Install uv by copying the binary from the official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Terraform version — update as needed
ARG TERRAFORM_VERSION=1.15.8
ARG TARGETARCH

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    jq \
    unzip \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Download and install Terraform for the selected target architecture
RUN curl -LO "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_${TARGETARCH}.zip" && \
    unzip "terraform_${TERRAFORM_VERSION}_linux_${TARGETARCH}.zip" -d /usr/local/bin && \
    rm "terraform_${TERRAFORM_VERSION}_linux_${TARGETARCH}.zip" && \
    chmod +x /usr/local/bin/terraform

# 2. Install Python tools using uv
# We use --system because we are inside a container and want the tools
# available globally in the image.
RUN uv pip install --system \
    boto3 \
    requests \
    pyyaml \
    jinja2 \
    python-dotenv \
    hvac \
    nac-validate

# These settings apply only to this version check. QEMU user-mode emulation can
# crash the amd64 Go runtime during garbage collection or the update check when
# building on an arm64 host. They are not persisted in the resulting image.
RUN GOGC=off CHECKPOINT_DISABLE=1 terraform --version && \
    python --version && \
    uv --version
